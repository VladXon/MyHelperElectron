{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",

  "shell": "pwsh",

  "mcp": {},

  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers"
  ],

  "lsp": true,

  "formatter": {
    "prettier": {
      "disabled": false
    }
  },

  "instructions": [
    "AGENTS.md"
  ],

  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "release/**",
      "*.db",
      "*.db-journal",
      ".superpowers/**",
      "docs/superpowers/**"
    ]
  },

  "permission": {
    "bash": "allow",
    "write": "allow",
    "edit": "allow"
  },

  "autoupdate": true,

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  }
}